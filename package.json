{
  "name": "krwnos",
  "version": "0.1.0",
  "private": true,
  "description": "KrwnOS — modular operating system for building digital states, companies and communities.",
  "homepage": "https://krwnos.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/KrwnOS/krwnos.git"
  },
  "bugs": {
    "url": "https://github.com/KrwnOS/krwnos/issues"
  },
  "license": "MIT",
  "workspaces": [
    "cli",
    "packages/sdk"
  ],
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "npm run build -w @krwnos/sdk && tsc --noEmit",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:watch": "vitest",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio",
    "cli": "node cli/bin/krwn.mjs",
    "setup": "tsx src/core/setup-state.ts",
    "watcher:treasury": "tsx scripts/treasury-watcher.ts",
    "worker:jobs": "tsx scripts/job-worker.ts",
    "ws:gateway": "tsx scripts/ws-gateway.ts",
    "telegram:poll": "tsx scripts/telegram-polling.ts",
    "compose:up": "docker compose -f deploy/docker-compose.yml up -d",
    "compose:down": "docker compose -f deploy/docker-compose.yml down",
    "compose:logs": "docker compose -f deploy/docker-compose.yml logs -f app"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1032.0",
    "@krwnos/sdk": "0.1.0",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.215.0",
    "@opentelemetry/instrumentation": "^0.215.0",
    "@opentelemetry/instrumentation-http": "^0.215.0",
    "@opentelemetry/resources": "^2.0.0",
    "@opentelemetry/sdk-trace-base": "^2.7.0",
    "@opentelemetry/sdk-trace-node": "^2.7.0",
    "@opentelemetry/semantic-conventions": "^1.37.0",
    "@prisma/client": "^5.22.0",
    "bullmq": "^5.74.1",
    "clsx": "^2.1.1",
    "decimal.js": "^10.6.0",
    "intl-messageformat": "^10.7.0",
    "ioredis": "^5.4.1",
    "next": "14.2.15",
    "nodemailer": "^8.0.5",
    "pino": "^10.3.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "reactflow": "^11.11.4",
    "tailwind-merge": "^2.5.4",
    "viem": "^2.21.0",
    "web-push": "^3.6.7",
    "ws": "^8.20.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.1",
    "@types/node": "^20.16.11",
    "@types/nodemailer": "^8.0.0",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.0",
    "@types/web-push": "^3.6.4",
    "@types/ws": "^8.18.1",
    "@vitest/coverage-v8": "^2.1.9",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.1",
    "eslint-config-next": "14.2.15",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "postcss": "^8.4.47",
    "prisma": "^5.22.0",
    "tailwindcss": "^3.4.13",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^2.1.9"
  },
  "engines": {
    "node": ">=18.17",
    "npm": ">=9.0.0"
  }
}
