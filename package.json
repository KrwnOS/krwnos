{
  "name": "krwnos",
  "version": "0.1.0",
  "private": true,
  "description": "KrwnOS — modular operating system for building digital states, companies and communities.",
  "homepage": "https://krwnos.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/KrwnOS/krwnos.git"
  },
  "bugs": {
    "url": "https://github.com/KrwnOS/krwnos/issues"
  },
  "license": "MIT",
  "workspaces": ["cli"],
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio",
    "cli": "node cli/bin/krwn.mjs",
    "setup": "tsx src/core/setup-state.ts",
    "compose:up": "docker compose -f deploy/docker-compose.yml up -d",
    "compose:down": "docker compose -f deploy/docker-compose.yml down",
    "compose:logs": "docker compose -f deploy/docker-compose.yml logs -f app"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "clsx": "^2.1.1",
    "ioredis": "^5.4.1",
    "next": "14.2.15",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwind-merge": "^2.5.4",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.16.11",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.1",
    "eslint-config-next": "14.2.15",
    "postcss": "^8.4.47",
    "prisma": "^5.22.0",
    "tailwindcss": "^3.4.13",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  },
  "engines": {
    "node": ">=18.17"
  }
}
