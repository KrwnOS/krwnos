# ---- Database ----
DATABASE_URL="postgresql://krwn:krwn@localhost:5432/krwnos?schema=public"

# ---- Redis (Event Bus / Realtime) ----
REDIS_URL="redis://localhost:6379"

# ---- Auth ----
AUTH_SECRET="replace-me-with-a-long-random-string"
AUTH_URL="http://localhost:3000"

# ---- Email (magic_email / SMTP) ----
# Optional SMTP (omit SMTP_HOST to disable outbound mail).
# SMTP_HOST="smtp.example.com"
# SMTP_PORT="587"
# SMTP_SECURE="false"
# SMTP_USER=""
# SMTP_PASS=""
# SMTP_FROM="KrwnOS <noreply@example.com>"

# ---- Automated backups (S3 / R2 — optional; job no-ops if bucket unset) ----
# KRWN_BACKUP_S3_BUCKET=""
# KRWN_BACKUP_S3_REGION="auto"
# KRWN_BACKUP_S3_ENDPOINT="https://<account>.r2.cloudflarestorage.com"
# KRWN_BACKUP_S3_ACCESS_KEY_ID=""
# KRWN_BACKUP_S3_SECRET_ACCESS_KEY=""
# KRWN_BACKUP_S3_PREFIX="krwn-backups"
# KRWN_BACKUP_RETENTION_COUNT="14"
# (use 0 to disable pruning — keep all manifests / objects)
# Or use AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY instead of KRWN_BACKUP_S3_* keys.
# KRWN_JOB_BACKUP_CRON="0 3 * * *"
# KRWN_JOB_BACKUP_TZ="UTC"

# ---- Misc ----
NODE_ENV="development"
# Pino: trace | debug | info | warn | error | fatal
LOG_LEVEL="info"
