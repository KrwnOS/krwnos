# ---- Database ----
DATABASE_URL="postgresql://krwn:krwn@localhost:5432/krwnos?schema=public"

# ---- Redis (Event Bus / Realtime) ----
REDIS_URL="redis://localhost:6379"
# Use Redis pub/sub for the kernel event bus (default when REDIS_URL is set).
# KRWN_REDIS_EVENT_BUS=0

# ---- WebSocket realtime gateway (optional; requires REDIS_URL) ----
# Browser connects here when set; otherwise chat/dashboard use SSE only.
# NEXT_PUBLIC_KRWN_WS_URL="ws://127.0.0.1:3010"
# KRWN_WS_PORT=3010
# KRWN_WS_HOST=0.0.0.0

# Presence: write-through to Redis (same REDIS_URL) for multi-instance online counts.
# KRWN_PRESENCE_REDIS=0

# ---- Auth ----
AUTH_SECRET="replace-me-with-a-long-random-string"
AUTH_URL="http://localhost:3000"

# ---- Email (magic_email / SMTP) ----
# Optional SMTP (omit SMTP_HOST to disable outbound mail).
# SMTP_HOST="smtp.example.com"
# SMTP_PORT="587"
# SMTP_SECURE="false"
# SMTP_USER=""
# SMTP_PASS=""
# SMTP_FROM="KrwnOS <noreply@example.com>"

# ---- Email digest (BullMQ; requires worker + SMTP for real sends) ----
# KRWN_EMAIL_DIGEST_ENABLED="1"
# In development, dry-run is default unless KRWN_EMAIL_DIGEST_DRY_RUN="0"
# KRWN_EMAIL_DIGEST_DRY_RUN="1"
# KRWN_JOB_EMAIL_DIGEST_DAILY_CRON="0 8 * * *"
# KRWN_JOB_EMAIL_DIGEST_DAILY_TZ="UTC"
# KRWN_JOB_EMAIL_DIGEST_WEEKLY_CRON="0 8 * * 1"
# KRWN_JOB_EMAIL_DIGEST_WEEKLY_TZ="UTC"

# ---- Automated backups (S3 / R2 — optional; job no-ops if bucket unset) ----
# KRWN_BACKUP_S3_BUCKET=""
# KRWN_BACKUP_S3_REGION="auto"
# KRWN_BACKUP_S3_ENDPOINT="https://<account>.r2.cloudflarestorage.com"
# KRWN_BACKUP_S3_ACCESS_KEY_ID=""
# KRWN_BACKUP_S3_SECRET_ACCESS_KEY=""
# KRWN_BACKUP_S3_PREFIX="krwn-backups"
# KRWN_BACKUP_RETENTION_COUNT="14"
# (use 0 to disable pruning — keep all manifests / objects)
# Or use AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY instead of KRWN_BACKUP_S3_* keys.
# KRWN_JOB_BACKUP_CRON="0 3 * * *"
# KRWN_JOB_BACKUP_TZ="UTC"

# ---- Activity log retention (Pulse + /admin/audit) ----
# Keep ActivityLog rows for this many days (default 365 if unset). 0 = unlimited (no delete).
# KRWN_ACTIVITY_LOG_RETENTION_DAYS="365"
# Daily prune schedule (UTC by default); requires Redis + npm run worker:jobs
# KRWN_JOB_ACTIVITY_REAPER_CRON="30 4 * * *"
# KRWN_JOB_ACTIVITY_REAPER_TZ="UTC"

# ---- Payroll (BullMQ; root treasury → PERSONAL, idempotent by UTC month) ----
# KRWN_JOB_PAYROLL_CRON="0 8 15 * *"
# KRWN_JOB_PAYROLL_TZ="UTC"

# ---- Telegram bot (optional; CredentialsRegistry — docs/DEPLOYMENT.md) ----
# KRWN_TELEGRAM_BOT_TOKEN=""
# KRWN_TELEGRAM_BOT_USERNAME=""
# KRWN_TELEGRAM_WEBHOOK_SECRET=""

# ---- Misc ----
NODE_ENV="development"
# Pino: trace | debug | info | warn | error | fatal
LOG_LEVEL="info"
